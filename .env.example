# Copy to .env and adjust. Values here are DEV DEFAULTS — never use them in prod.

ENV=development
ADDR=:8080
LOG_LEVEL=info

# Postgres + Redis (defaults match docker-compose for local `make run`).
DATABASE_URL=postgres://heimdal:heimdal@localhost:5432/heimdal?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# Secret used to HMAC API keys before storage (>= 16 chars). Rotating it
# invalidates all existing API keys.
API_KEY_PEPPER=dev-pepper-change-me-please

# Secret used to sign dashboard session tokens (>= 16 chars).
SESSION_SECRET=dev-session-secret-change-me

# AES-256-GCM key for encrypting provider credentials at rest.
# Must decode (hex or base64) to exactly 32 bytes. This is 64 hex chars.
ENCRYPTION_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff
ENCRYPTION_KEY_VERSION=1

# Dashboard origin(s) allowed for CORS (comma-separated). Use * to allow all.
CORS_ORIGINS=http://localhost:3000

# Response cache TTL for deterministic (temperature 0/unset) completions.
# 0 disables caching. Example: 5m. Clients opt out per-request with the
# "x-no-cache: true" header.
CACHE_TTL=0

# Optional upstream base-URL overrides (e.g. for a mock server in tests).
# OPENAI_BASE_URL=
# ANTHROPIC_BASE_URL=
# GOOGLE_BASE_URL=
